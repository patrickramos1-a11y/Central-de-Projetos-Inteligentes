{
  "name": "central-de-projetos-inteligentes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "cf:dev": "wrangler dev --local --port 8787",
    "cf:deploy": "wrangler deploy",
    "cf:deploy:api": "wrangler deploy",
    "cf:d1:migrate:local": "wrangler d1 migrations apply central-projetos-ia --local",
    "cf:d1:migrate:remote": "wrangler d1 migrations apply central-projetos-ia --remote",
    "cf:pages:deploy": "bun run build && wrangler pages deploy dist --project-name central-de-projetos-inteligentes",
    "cf:export:supabase": "bun scripts/export-supabase-to-d1.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "wrangler": "^4.106.0"
  }
}
